ype.mtsnb-content {\n    text-align: left !important;\n}\n.nav-utility span.grey {\n    color: #003057;\n}\n@media (max-width: 767px){\n.nav-utility .module.left {\n    float: right !important;\n    margin-right: 0px;\n    padding-right: 0px;\n}\n.nav-utility span.grey {\n    padding-right: 0px !important;\n}\n.nav-utility .sub span + span, .nav-utility .sub span {\n    padding: 0 !important;\n}\n}\n.module-group.right .module.left:first-child {\n    padding-right: 0px;\n}\n\nnav.absolute.fixed {\n    top: 0px !important;\n}\n\n.has-mtsnb .mtsnb {\n    z-index: 0;\n}\n/***Footer Fixes***/\n.footer-1 .sub {\n    opacity: 1 !important;\n    font-size: 13px;\n}\n\n/***Blog Page Edits***/\n.type-post .post-title {\n    display: none;\n}\n.post-template-default section.page-title.page-title-4.bg-secondary {\n    display: none;\n}\n\n.type-post .post-content h1 {\n    font-size: 38px;\n    line-height: 45px;\n}\n\n.type-post .post-content h2 {\n    font-size: 28px;\n    line-height: 35px;\n}\n.type-post .post-content h1 {\n    font-weight: 600;\n}\n\n/***Removing MedChat***/\nbody.mc-theme-medchat {\n    display: none !important;\n}\na {\n    color: #23527c;\n}\ninput[type=\"submit\"], button[type=\"submit\"] {\n    border: 2px solid #23527c;\n    background: #23527c;\n}\na.btn {\n    color: #23527c;\n    border: 2px solid #23527c;\n}\n.btn:hover {\n    background: #23527c;\n}\na:hover {\n    color: #23527c;\n    text-decoration: none;\n}\n.bg-primary {\n    background: #23527c!important;\n}\n.pagination li a:hover, .pagination li.active a, .pagination li.active:hover a {\n    background: #23527c;\n    color: #fff;\n    border-color: #23527c;\n}\n.accordion-1 .active .title {\n    background: #23527c;\n    color: #fff;\n}\nul#menu-amp-menu ul.subnav a {\n    color: #fff !important;\n}\ndiv#wpadminbar a {\n    color: #fff !important;\n}\ndiv#upercase.vc_btn3-container.vc_btn3-center a {\n    color: #fff !important;\n}\nsection.bg-dark.pt0.pb0.vc_row.wpb_row.vc_row-fluid.bg-dark.pt0.pb0 h6 a {\n    color: #fff !important;\n}\n.whitetxt a {\n    color: #fff !important;\n}\n\n/***Click to Call Phone Number***?\n.nav-utility span.orange {\n    z-index: 1 !important;\n}\n\n.row.masonry.masonryFlyIn.mb40.fadeIn img.mb24.wp-post-image {\n    object-fit: cover !important;\n}\n\n/***404 Page Edit***/\n.error404 .floating_content_full_details {\n    display: none !important;\n}\n\n/***Mobile Nav Dropdown Fix***/\n@media all and (max-width: 800px) {\n.module-group.right .menu li {\n    font-size: 20px !important;\n    margin-right: 25%;\n    width: 100%;\n}\n.has-dropdown:after {\n    padding-left: 50%;\n}\nul.menu {\n    width: 95%;\n}\n}\n.type-team.status-publish .row {\n    margin-top: 30px !important;\n}\n.footer-disclaimer {  \nfloat: left;  \n}  \n.subfooter-row .col-sm-6 {  \nwidth: 100%;  \n} \n\n@media only screen and (min-width: 767px) { \n\nul.list-inline.social-list {\n    float: left;\n    margin-top: -470px;\n    margin-left: -20px;\n}\ni.ti-facebook, i.ti-youtube, i.ti-instagram, i.ti-linkedin {\n    font-size: 20px;\n}\n.footer-1 div#search-3 {\n    margin-bottom: 25px;\n}\n.subfooter-row .col-sm-6 {\n    padding-left: 0px;\n}\nelement.style {\n}\n.subfooter-row a:hover {\n    color: #f7f7f7 !important;\n}\n.subfooter-row a {\n    color: white !important;\n}\n.menu > li {\n    margin-right: 12px;\n}\n} \n.menu li a {\n    opacity: 1;\n}\na.btn.btn-sm.fade-half.back-to-top.inner-link {\n    color: #A2A89E !important;\n}\n.aiosrs-rating-wrap {\n    display: none !important;\n}\ndiv#gtranslate_wrapper {\n    top: 0px !important;\n    left: 0 !important;\n    width: 150px;\n}\nselect#gtranslate_selector {\n    width: 200px !important;\n    background-color: #f7f7f7 !important;\n    height: 30px;\n}\ni.ti-angle-down {\n    top: 5px !important;\n}\n\n#gtranslate_wrapper .select-option {\n    position: relative;\n    cursor: pointer;\n    height: 30px;\n    overflow: hidden;\n    float: left;\n}\n\n/*WP Form Styling*/\n.choices.wpforms-field-row.wpforms-field-small {\n    margin: auto !important;\n}\n.wpforms-submit {\n    border: 2px solid #23527c !important;\n    background: #23527c !important;\n    color: white !important;\n}\n.single-post .col-md-3 a.cta-phone-number {\n    margin-left: 0px !important;\n}\n.wpforms-field-container i.ti-angle-down {\n    display: none !important;\n}\n\n/***Footer Updates***/\n.footer-1 a {\n    color: #ffffff !important;\n    font-weight: 600 !important;\n}\n.footer-disclaimer {\n    float: right !important;\n    text-align: right !important;\n    margin-right: -15px !important;\n}\ni.ti-facebook, i.ti-youtube, i.ti-instagram, i.ti-linkedin {\n    font-size: 20px;\n}\n.bg-dark .social-list a {\n    font-size: 20px !important;\n}\n.be-main-container {\n    padding: 15px 15px 95px 15px !important;\n}\n\n@media only screen and (max-width: 766px) {\nfooter {\n    padding-bottom: 300px;\n}\n.footer-disclaimer {\n    float: left !important;\n    text-align: left !important;\n    margin-right: -15px !important;\n}\nul.list-inline.social-list {\n    margin-top: -180px !important;\n    float: left;\n    height: 40px !important;\n    padding-top: 10px;\n}\n.social-list li {\n    margin-left: 0px !important;\n}\n.subfooter-row {\n    margin-top: 30px;\n}\n.footer-1 .row {\n    height: 1050px;\n}\n}\n@media only screen and (min-width: 767px) {\n    ul.list-inline.social-list {\n        float: left;\n        margin-top: -400px;\n        margin-left: -20px;\n    }\n}\n\n/* Add padding to create space for the caret on dropdown menu items on homepage */\n.home .has-dropdown {\n    padding-right: 28px; /* Add enough space for the caret to avoid overlap */\n}\n\n/* Adjust caret color and size, keeping the initial perfect positioning */\n.home .has-dropdown:after {\n    position: absolute;\n    top: 0; /* Keep original vertical positioning */\n    right: 10px; /* Maintain original right position */\n    font-size: 11px; /* Adjust size to match your preference */\n    content: \"\\e64b\"; /* Use the Themify caret icon */\n    font-family: 'themify'; /* Ensure caret uses the Themify icon font */\n    color: #666666 !important; /* Change the caret color to dark */\n    font-weight: normal !important; /* Ensure caret is thin */\n}\n\n/* Remove any extra custom arrows from homepage non-sticky menu */\n.home .menu-item-has-children > a::after {\n    content: none !important; /* Remove any extra arrows */\n}\n\n\n/* Ensure no extra arrows are present in the sticky or submenus */\nnav.fixed .menu-item-has-children > a::after,\n.menu-item-has-children > ul > li.menu-item-has-children > a::after {\n    content: none !important; /* Prevent extra arrows in sticky or submenu items */\n}\n\n\n/* DB: Styling fix for menu-item with current ancestor/parent state */\n.menu-item.menu-item-type-custom.current-menu-ancestor.current-menu-parent {\n    line-height: 20px;\n    margin-top: 0px !important; /* Ensure consistent margin for current ancestor/parent */\n}\n\n/* DB: Combined styling fix for specific menu items (menu-item-25441, menu-item-25443, and menu-item-25444) */\nli#menu-item-25441.menu-item,\nli#menu-item-25443.menu-item.menu-item-type-custom.current-menu-ancestor.current-menu-parent,\nli#menu-item-25444.menu-item {\n    line-height: 20px;\n    margin-top: 45px !important; /* Add 45px top margin */\n}\n\n/* DB: Adjust spacing for mobile and tablet (max-width: 991px) */\n@media (max-width: 991px) {\n    li#menu-item-25441.menu-item,\n    li#menu-item-25443.menu-item.menu-item-type-custom.current-menu-ancestor.current-menu-parent,\n    li#menu-item-25444.menu-item {\n        margin-top: 0px !important; /* Remove extra margin on mobile/tablet */\n        line-height: normal !important; /* Set normal line height */\n        padding-top: 0px !important; /* Ensure consistent top padding */\n        padding-bottom: 0px !important; /* Ensure consistent bottom padding */\n    }\n}\n\n/* DB: Ensure submenus remain within viewport on tablets and smaller screens (max-width: 1024px) */\n@media (max-width: 1024px) {\n    .menu > li > ul > li > ul {\n        left: auto !important; /* Prevent submenus from going off the screen to the left */\n        right: 0 !important; /* Align submenus with the right edge */\n        top: 0 !important; /* Align submenu to the top of the parent */\n        position: absolute !important; /* Ensure proper positioning */\n    }\n\n    /* DB: Make sure parent items with submenus remain clickable */\n    .menu > li > ul > li > a {\n        pointer-events: auto !important; /* Enable pointer events for clickable parent items */\n    }\n\n    /* DB: Remove custom arrow in submenu, retain default arrow */\n    .menu > li > ul > li:has(ul) > a::after {\n        content: none !important; /* Remove custom arrow */\n    }\n}\n\n/* DB: Mobile-specific adjustments for better touch experience (max-width: 767px) */\n@media (max-width: 767px) {\n    .menu > li > ul > li > ul {\n        position: static !important; /* Stack submenus directly under parent menu */\n        width: 100% !important; /* Make submenu full width */\n        right: auto !important; /* Remove right alignment */\n        left: 0 !important; /* Align submenu to the left */\n        margin-left: -20px !important; /* Prevent submenu from overlapping */\n    }\n\n    /* DB: Ensure parent menu items are fully clickable on mobile */\n    .menu > li > ul > li > a {\n        display: block;\n        width: 100%; /* Make parent items take full width */\n        padding: 10px 0; /* Add padding for better touch experience */\n    }\n\n    /* DB: Position default arrow closer to text in last-level dropdown */\n    .menu > li > ul > li > ul > li:has(ul) > a::after {\n        content: \"\\276F\"; /* Default arrow */\n        font-size: 1.2em;\n        margin-left: 6px; /* Position arrow closer to text */\n        display: inline-block;\n        vertical-align: middle; /* Align arrow with text */\n        transform: rotate(90deg); /* Rotate arrow to point downwards */\n    }\n}\n/* DB: End styling fix */\n/* DB: Ensure the top-level parent (menu-item-25441) always has a gray caret */\n@media (max-width: 991px) {\n    /* Target the top-level parent with the ID of menu-item-25441 */\n    #menu-item-25441.has-dropdown:after {\n        color: #808080!important; /* Gray caret for this top-level parent */\n    }\n\n    /* Maintain white caret for dropdowns inside the submenu (for nested dropdowns) */\n    body.home nav.transparent .has-dropdown .has-dropdown:after {\n        color: #ffffff!important; /* White caret for nested dropdown items */\n    }\n}\n/* DB: White caret for all dropdowns (except uppermost parent) on homepage (desktop and sticky menu) */\n@media (min-width: 992px) {\n    /* White caret for child dropdowns on homepage (excluding uppermost parent) */\n    body.home nav.transparent .has-dropdown .has-dropdown:after {\n        color: #ffffff!important; /* White caret for all nested dropdowns */\n    }\n}\n\n/* DB: Sticky menu fix for white caret (excluding uppermost parent) on homepage */\nnav.sticky-menu {\n    /* White caret for child dropdowns in sticky menu (excluding uppermost parent) */\n    body.home nav.sticky-menu .has-dropdown .has-dropdown:after {\n        color: #ffffff!important; /* White caret for all nested dropdowns in sticky menu */\n    }\n\n}\nh4.mb0:empty,\nh4.mb0:empty::before,\nh4.mb0:empty::after {\n    display: none !important;\n}\n/* Custom styling for <h1> on team pages */\n/* Added by DB (Dan Batten) to ensure specific styles for team member names */\nbody.single-team h1.mb0 {\n    margin-bottom: -15px !important;\n    font-size: 25px;\n    font-weight: 500;\n}\n/* ==========================================================================\n   Dev Notes: Social Icons Mobile Fix, Hover Effects & Clearfix\n   --------------------------------------------------------------------------\n   1) Re-enable clicks on preview-only anchors\n   2) Expand tap targets on touchscreens\n   3) Apply hover/active effects on desktop & mobile\n   4) Clear any floats so nothing overlaps on small screens\n   ========================================================================== */\n\n/* 1) Undo Customizer’s pointer-events:none lock */\n.customize-unpreviewable {\n  pointer-events: auto !important;\n}\n\n/* 2) Improve tap targets by making links inline-block with padding */\nul.list-inline.social-list li a {\n  display: inline-block;    /* allows padding/width on the <a> */\n  padding: 0px;             /* increase hit area for touch */\n  margin: 0 0px;            /* spacing between icons */\n  line-height: 1;           /* vertically center the icon */\n}\n\n/* 3) Trigger hover/active effects for mouse & touch users */\nul.list-inline.social-list li a:hover i,\nul.list-inline.social-list li a:active i,\nul.list-inline.social-list li a:focus i {\n  color: #ffffff;                  /* change icon color on interaction */\n  transform: scale(1.1);           /* slightly enlarge icon */\n  transition: transform 0.2s ease; /* smooth scaling animation */\n}\n\n/* 4) Clear any floated elements that come after the social list */\n.social-list-clear {\n  clear: both;   /* forces following content below any floats */\n  width: 100%;   /* spans full container (optional) */\n  height: 0;     /* no visual height—purely a clearfix */\n}\n/* Desktop styling for main team member names on the team page */\n@media (min-width: 1025px) {\n    .about-our-team h2.uppercase,\n    body.page-id-56 h2.uppercase { /* Replace XXXX with the page ID of /about/our-team/ */\n        font-size: 1.5em!important;\n        line-height: 1.5em!important;\n    }\n}\n@media (min-width: 1025px) {\n  body.home .image-tile .title h2.uppercase {\n    font-size: 1.5em;\n    line-height: 1.5em;\n  }\n}\nbody.postid-50657 .type-post .post-content h1 {\n  display: none !important;\n}\n\n/*# sourceURL=ebor-style-inline-css */\n</style>\n<link rel='stylesheet' id='foundry-style-css' href='https://www.cliff