ves Margin at end of copy block */\n.wpb_content_element {\nmargin-bottom: 0;\n}\n\n/* Accordion answers don't get cut off short */\n.accordion li.active .content {\nmax-height: none;\n}\n\n/* Separator Margins */\n.vc_separator {\nmargin: 2em 0 3em 0;\n}\n\n/* Removes \"Call\" From Top Header */\nspan.grey {\ndisplay: none;\n}\n\n/* Breadcrumb Backslashes */\n.breadcrumb-2 > li + li:before {\ncolor: white;\n}\n\n/* Search Bar */\n.widget-handle .function {\nwidth: 100vw;\nbackground: none;\n-webkit-box-shadow: none;\nbox-shadow: none;\nmargin-top: -26px;\n-webkit-transform: translateY(-10px);\n-moz-transform: translateY(-0px);\n}\n.widget-handle .search-form {\npadding: 0;\n}\n\n/* Justifies second line of sentence to bullets on lists */\nul li {\n    list-style-position: outside;\n    margin-left: 1em;\n}\n\n/* Footer horiz. seperator color */\nfooter hr {\nborder-color: #a2b7c2 !important;\n}\n\n/* Format Buttons */\n.vc_btn3 {\ntext-transform: uppercase;\nletter-spacing: 1px;\nfont-family: \"Tenor Sans\";\nfont-size: .8em !important;\n}\n\n\n/**************** MOBILE ONLY ****************/\n/* Mobile min-width 641px and max-width 1024px */\n\n@media only screen and (max-width: 768px) {\n\n/* Search Bar - Mobile */\n.widget-handle .function {\nmargin-top: 0px;\nwidth: 100%;\n}\n}\n\n\n/****************JB CODE****************/\n\n@media (max-width: 767px){\nimg.logo.logo-dark {\n    margin-top: 0px;\n    vertical-align: top !important;\n     }\nimg.logo.logo-light {\n    margin-top: 0px;\n    vertical-align: top !important;\n     }\n}\n\n/* Bringing up top of fold */\n@media (min-width: 992px){\n.nav-bar .module, .nav-bar .module-group {\n    height: 60px;\n     }\nimg.logo.logo-dark {\n    margin-top: 15px;\n    vertical-align: top !important;\n    max-width: 350px !important;\n     }\nimg.logo.logo-light {\n    margin-top: 15px;\n    vertical-align: top !important;\n    max-width: 350px !important;\n     }\n}\n\n/* Moving Up Nav-Items */\n.right .module.left {\n    margin-top: -5px;\n}\n\n/* Moving Up Nav-Items */\n.nav-utility span.sub {\n    font-size: 15px;\n}\n/***Header Adjustments***/\n.nav-utility a.btn.btn-sm {\n    border: none;\n    padding-right: 10px;\n}\n\n@media all and ( min-width: 768px ){\n.nav-utility {\n  margin-right: 32px;\nmargin-top: 15px;\n    margin-bottom: 0px;\n}\n}\n\n.module.left {\n    margin-right: 8px;\n}\n\n.nav-utility .module.left {\n    padding-right: 5px;\n}\n\nul#menu-amp-menu {\n    margin-right: 10px;\n}\n\n.nav-utility {\n    height: 30px !important;\n}\n\n.nav-utility > div:last-child a {\n    position: relative !important;\n    left: 5px !important;\n}\n.nav-utility .sub span {\n    font-family: Tenor Sans, \"Helvetica Neue\", Helvetica, Arial, sans-serif;\n}\n\na.number {\n    font-family: Tenor Sans, \"Helvetica Neue\", Helvetica, Arial, sans-serif;\n}\n.nav-utility a.number {\n    color: #003057;\n}\n/***End Header Adjustments***/\n\n/***MedChat Color Changes***/\nbutton.mc-expand {\n    background-color: #a2b7c2 !important;\n}\n.wrapper.scroll-area .widgetBackgroundColor {\n    background-color: #a2b7c2 !important;\n}\n/***End MedChat Color Changes***/\n\nA.cta-phone-number {\n\tMargin-left: 41.5%;\n\tFont-size: 24px; \n\tFont-family: Tenor Sans, \"Helvetica Neue\", Helvetica, Arial, sans-serif;\n}\n\n/***Menu DropDown to the left***/\n@media (min-width: 768px){\n.menu > li > ul > li > ul {\n    left: auto;\n    right: 110%;\n    top: 0;\n}\n}\n@media (max-width: 767px){\n    /*.nav-container {\n        min-height: 100px;\n        position: fixed;\n        z-index: 100 !important;\n        width: 100%;\n    }\n    .main-container {\n        margin-top: 100px;\n    }*/\n    .module.widget-handle.mobile-toggle {\n    float: right;\n    position: absolute;\n    top: 0px !important;\n    }\n.module-group .left {\n    background-color: white;\n    margin-top: -30px !important;\n}\nbody nav .logo { top: 0; }\nnav .module.widget-handle.mobile-toggle.right.visible-sm.visible-xs {\ntop: