text-transform: uppercase;\nletter-spacing: 1px;\nfont-family: \"Tenor Sans\";\nfont-size: .8em !important;\n}\n\n\n/**************** MOBILE ONLY ****************/\n/* Mobile min-width 641px and max-width 1024px */\n\n@media only screen and (max-width: 768px) {\n\n/* Search Bar - Mobile */\n.widget-handle .function {\nmargin-top: 0px;\nwidth: 100%;\n}\n}\n\n\n/****************JB CODE****************/\n\n@media (max-width: 767px){\nimg.logo.logo-dark {\n    margin-top: 0px;\n    vertical-align: top !important;\n     }\nimg.logo.logo-light {\n    margin-top: 0px;\n    vertical-align: top !important;\n     }\n}\n\n/* Bringing up top of fold */\n@media (min-width: 992px){\n.nav-bar .module, .nav-bar .module-group {\n    height: 60px;\n     }\nimg.logo.logo-dark {\n    margin-top: 15px;\n    vertical-align: top !important;\n    max-width: 350px !important;\n     }\nimg.logo.logo-light {\n    margin-top: 15px;\n    vertical-align: top !important;\n    max-width: 350px !important;\n     }\n}\n\n/* Moving Up Nav-Items */\n.right .module.left {\n    margin-top: -5px;\n}\n\n/* Moving Up Nav-Items */\n.nav-utility span.sub {\n    font-size: 15px;\n}\n/***Header Adjustments***/\n.nav-utility a.btn.btn-sm {\n    border: none;\n    padding-right: 10px;\n}\n\n@media all and ( min-width: 768px ){\n.nav-utility {\n  margin-right: 32px;\nmargin-top: 15px;\n    margin-bottom: 0px;\n}\n}\n\n.module.left {\n    margin-right: 8px;\n}\n\n.nav-utility .module.left {\n    padding-right: 5px;\n}\n\nul#menu-amp-menu {\n    margin-right: 10px;\n}\n\n.nav-utility {\n    height: 30px !important;\n}\n\n.nav-utility > div:last-child a {\n    position: relative !important;\n    left: 5px !important;\n}\n.nav-utility .sub span {\n    font-family: Tenor Sans, \"Helvetica Neue\", Helvetica, Arial, sans-serif;\n}\n\na.number {\n    font-family: Tenor Sans, \"Helvetica Neue\", Helvetica, Arial, sans-serif;\n}\n.nav-utility a.number {\n    color: #003057;\n}\n/***End Header Adjustments***/\n\n/***MedChat